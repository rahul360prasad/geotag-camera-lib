<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AquaStack" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Light theme customizations -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/page_background</item>
        <item name="colorPrimary">@color/brand_ocean</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSurface">@color/surface_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.AquaStack" parent="Base.Theme.AquaStack" />

    <style name="Widget.AquaStack.TextInputLayout.OutlinedBox.PurpleDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/brand_purple</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/brand_purple</item>
        <item name="android:textColorHint">@color/brand_purple</item>
        <item name="endIconTint">@color/brand_purple</item>
        <item name="startIconTint">@color/brand_purple</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface_primary</item>
    </style>

    <style name="Widget.AquaStack.TextInputLayout.OutlinedBox.OriginalDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/ocean_blue_primary</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/ocean_blue_primary</item>
        <item name="android:textColorHint">@color/ocean_blue_primary</item>
        <item name="endIconTint">@color/ocean_blue_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface_primary</item>
    </style>

</resources>