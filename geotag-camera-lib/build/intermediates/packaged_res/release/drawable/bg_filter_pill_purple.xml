<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1F3C" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#7C3AED" />
            <padding android:left="14dp" android:right="36dp" android:top="14dp" android:bottom="14dp"/>
        </shape>
    </item>
    <item
        android:gravity="center_vertical|end"
        android:right="12dp"
        android:drawable="@drawable/ic_chevron_down_white" />
</layer-list>
