<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22FF3B30">
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="#22FF3B30" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="#FFFF3B30" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#0DFF3B30" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="#33FF3B30" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
