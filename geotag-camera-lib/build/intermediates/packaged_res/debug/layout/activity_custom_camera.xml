<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 1 — Full-screen CameraX Preview                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 2 — Aspect Ratio Masks                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/mask_top"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <View
        android:id="@+id/mask_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 3 — 3x3 Rule-of-Thirds Grid Lines Overlay           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_grid_lines"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:id="@+id/grid_v1"
            android:layout_width="0.8dp"
            android:layout_height="match_parent"
            android:background="#30FFFFFF"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/grid_v2"
            app:layout_constraintHorizontal_bias="0.333" />

        <View
            android:id="@+id/grid_v2"
            android:layout_width="0.8dp"
            android:layout_height="match_parent"
            android:background="#30FFFFFF"
            app:layout_constraintLeft_toRightOf="@id/grid_v1"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintHorizontal_bias="0.5" />

        <View
            android:id="@+id/grid_h1"
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="#30FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/grid_h2"
            app:layout_constraintVertical_bias="0.333" />

        <View
            android:id="@+id/grid_h2"
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="#30FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/grid_h1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 4 — Horizon / Level Overlay                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/layout_horizon_level"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Left static tick mark -->
        <View
            android:id="@+id/level_static_left"
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:background="#80FFFFFF"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true" />

        <!-- Right static tick mark -->
        <View
            android:id="@+id/level_static_right"
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:background="#80FFFFFF"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true" />

        <!-- Rotating horizon line (turns gold when level) -->
        <View
            android:id="@+id/view_horizon_line"
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="@android:color/white"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 5 — Tap-to-Focus + Exposure Slider HUD              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_focus_hud"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- L-bracket focus corners via ic_focus_ring drawable -->
        <View
            android:id="@+id/view_focus_ring"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/ic_focus_ring"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Vertical exposure track line -->
        <View
            android:id="@+id/exposure_line"
            android:layout_width="1.5dp"
            android:layout_height="90dp"
            android:background="#80FFD700"
            android:layout_marginStart="10dp"
            app:layout_constraintLeft_toRightOf="@id/view_focus_ring"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Sun exposure handle icon -->
        <ImageView
            android:id="@+id/icon_exposure_sun"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_sun"
            app:layout_constraintLeft_toLeftOf="@id/exposure_line"
            app:layout_constraintRight_toRightOf="@id/exposure_line"
            app:layout_constraintTop_toTopOf="@id/exposure_line"
            app:layout_constraintBottom_toBottomOf="@id/exposure_line" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 6 — Timer Countdown Overlay                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Dim vignette behind timer -->
    <View
        android:id="@+id/vignette_timer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <TextView
        android:id="@+id/tv_timer_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3"
        android:textColor="#FFD700"
        android:textSize="100sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:fontFamily="sans-serif-light"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 1 — Top Control Bar (Status bar aware)               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_camera_top_bar"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        android:translationZ="10dp">

        <!-- Left cluster: Flash -->
        <ImageButton
            android:id="@+id/btn_top_flash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_control_btn"
            android:src="@drawable/ic_flash_off"
            android:padding="10dp"
            app:tint="@android:color/white"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Left cluster: Timer (hidden when off) -->
        <ImageButton
            android:id="@+id/btn_top_timer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_control_btn"
            android:src="@drawable/ic_timer_off"
            android:padding="10dp"
            android:visibility="gone"
            app:tint="@android:color/white"
            app:layout_constraintLeft_toRightOf="@id/btn_top_flash"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Center: Expand Settings Chevron -->
        <ImageButton
            android:id="@+id/btn_expand_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_control_btn"
            android:src="@drawable/ic_chevron_down_white"
            android:padding="12dp"
            app:tint="@android:color/white"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Right: Aspect Ratio Pill -->
        <TextView
            android:id="@+id/btn_top_ratio"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="4:3"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_dock_chip"
            android:paddingHorizontal="14dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 2 — Settings Dock Drawer                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/layout_settings_dock"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E5000000"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:visibility="gone"
        android:translationZ="9dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:divider="@null">

            <!-- Flash Chip -->
            <LinearLayout
                android:id="@+id/opt_flash"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dock_chip"
                android:paddingVertical="0dp"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/img_dock_flash"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flash_off"
                    app:tint="@android:color/white" />
                <TextView
                    android:id="@+id/tv_dock_flash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flash"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- Timer Chip -->
            <LinearLayout
                android:id="@+id/opt_timer"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dock_chip"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/img_dock_timer"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_timer_off"
                    app:tint="@android:color/white" />
                <TextView
                    android:id="@+id/tv_dock_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timer"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- Ratio Chip -->
            <LinearLayout
                android:id="@+id/opt_ratio"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dock_chip"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tv_dock_ratio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4:3"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- Grid Chip -->
            <LinearLayout
                android:id="@+id/opt_grid"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dock_chip"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tv_dock_grid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grid"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- Level Chip -->
            <LinearLayout
                android:id="@+id/opt_level"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dock_chip"
                android:paddingHorizontal="14dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tv_dock_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 3 — Geotag / Watermark Info Card                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/cv_watermark_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="152dp"
        android:background="@drawable/bg_geotag_glass"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginStart="3dp">

            <!-- Satellite Map Thumbnail -->
            <FrameLayout
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_gravity="center_vertical">

                <!-- Satellite map background -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1B3A2D">

                    <WebView
                        android:id="@+id/map_webview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <!-- Location Data Panel (right side) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_gravity="center_vertical">

                <!-- Address -->
                <TextView
                    android:id="@+id/tv_overlay_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fetching location..."
                    android:textColor="#FFFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:lineSpacingExtra="1dp" />

                <!-- Coordinates in cyan -->
                <TextView
                    android:id="@+id/tv_overlay_coords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lat: 0.000000   Long: 0.000000"
                    android:textColor="#00D4FF"
                    android:textSize="9.5sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />

                <!-- Datetime -->
                <TextView
                    android:id="@+id/tv_overlay_datetime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date &amp; Time"
                    android:textColor="#99FFFFFF"
                    android:textSize="9.5sp"
                    android:layout_marginTop="2dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#20FFFFFF"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="5dp" />

                <!-- Weather 2x2 Grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- Wind -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wind  "
                            android:textColor="#70FFFFFF"
                            android:textSize="8.5sp" />
                        <TextView
                            android:id="@+id/tv_overlay_wind"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 km/h"
                            android:textColor="#FFFFFF"
                            android:textSize="8.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Pressure -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pres  "
                            android:textColor="#70FFFFFF"
                            android:textSize="8.5sp" />
                        <TextView
                            android:id="@+id/tv_overlay_pressure"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1012 hPa"
                            android:textColor="#FFFFFF"
                            android:textSize="8.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Humidity -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hum  "
                            android:textColor="#70FFFFFF"
                            android:textSize="8.5sp" />
                        <TextView
                            android:id="@+id/tv_overlay_humidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 %"
                            android:textColor="#FFFFFF"
                            android:textSize="8.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Temp -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temp  "
                            android:textColor="#70FFFFFF"
                            android:textSize="8.5sp" />
                        <TextView
                            android:id="@+id/tv_overlay_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="38 °C"
                            android:textColor="#FFFFFF"
                            android:textSize="8.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </GridLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 4 — Zoom Level Pills                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_zoom_pills"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_zoom_pill"
        android:paddingHorizontal="6dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/cv_watermark_overlay"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/btn_zoom_wide"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text=".6x"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btn_zoom_1x"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="1x"
            android:textColor="#00D4FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_zoom_active"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btn_zoom_2x"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="2x"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="@android:color/transparent" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 5 — Camera Mode Selector                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_mode_carousel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/layout_capture_bar">

        <!-- VIDEO mode -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="24dp">
            <TextView
                android:id="@+id/mode_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
            <!-- Invisible indicator (shown when active) -->
            <View
                android:id="@+id/mode_video_dot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#FFD700"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- PHOTO mode (active by default) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="24dp">
            <TextView
                android:id="@+id/mode_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
            <!-- Active gold dot indicator -->
            <View
                android:id="@+id/mode_photo_dot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#FFD700"
                android:visibility="visible" />
        </LinearLayout>

        <!-- PRO mode -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="24dp">
            <TextView
                android:id="@+id/mode_pro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRO"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
            <!-- Invisible indicator (shown when active) -->
            <View
                android:id="@+id/mode_pro_dot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_neon_circle"
                android:backgroundTint="#FFD700"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ZONE 6 — Bottom Capture Bar                               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_capture_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_capture_bar"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Gallery / Thumbnail (Bottom Left) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_thumbnail"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="32dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent">

            <!-- Photo thumbnail fills circle — clipped by CardView cornerRadius -->
            <ImageView
                android:id="@+id/btn_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_photo_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- White ring border overlay (sits on top of CardView) -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="32dp"
            android:background="@drawable/bg_thumbnail_border"
            app:layout_constraintTop_toTopOf="@id/cv_thumbnail"
            app:layout_constraintBottom_toBottomOf="@id/cv_thumbnail"
            app:layout_constraintLeft_toLeftOf="parent" />

        <!-- Shutter Button (Center) -->
        <FrameLayout
            android:id="@+id/btn_shutter_container"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <!-- Cyan outer ring -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_shutter_outer_pro" />

            <!-- White inner press circle -->
            <View
                android:id="@+id/btn_shutter_inner"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_shutter_inner_pro" />

        </FrameLayout>

        <!-- Camera Switch (Bottom Right) -->
        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_control_btn"
            android:src="@drawable/baseline_cameraswitch_24"
            android:padding="13dp"
            app:tint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LAYER 7 — Full Screen Image Preview Overlay               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_image_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone"
        android:elevation="20dp">

        <ImageView
            android:id="@+id/img_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- Bottom Bar for Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#80000000"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btn_preview_retake"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="16dp"
                android:text="Retake"
                android:textColor="@android:color/white"
                android:backgroundTint="#444444"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="25dp" />

            <Button
                android:id="@+id/btn_preview_use"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="16dp"
                android:text="Use Photo"
                android:textColor="@android:color/black"
                android:backgroundTint="#FFD700"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="25dp" />

        </LinearLayout>

        <!-- Loading overlay when saving/processing -->
        <FrameLayout
            android:id="@+id/layout_preview_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#FFD700" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
